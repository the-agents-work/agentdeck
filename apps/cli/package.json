{
  "name": "pocket-agents",
  "version": "0.1.0",
  "description": "Mobile remote control for coding agents (Claude Code, Codex). Open a URL on your phone, chat with agents running on your laptop, from anywhere.",
  "type": "module",
  "bin": {
    "pocket-agents": "./dist/index.js"
  },
  "files": [
    "dist/",
    "static/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/index.js --external=cloudflared --external=@anthropic-ai/claude-agent-sdk --external=qrcode-terminal --banner '#!/usr/bin/env bun' && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "cloudflared": "^0.7.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@pocket-agents/adapters": "*",
    "@pocket-agents/protocol": "*",
    "@types/bun": "^1.1.10",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.6.2"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "keywords": [
    "claude-code",
    "codex",
    "mobile",
    "remote",
    "ai",
    "agent",
    "anthropic",
    "openai",
    "dashboard",
    "pwa"
  ],
  "homepage": "https://github.com/the-agents-work/pocket-agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-agents-work/pocket-agents.git"
  },
  "bugs": {
    "url": "https://github.com/the-agents-work/pocket-agents/issues"
  },
  "license": "MIT"
}
